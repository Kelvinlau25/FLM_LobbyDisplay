@page
@model IndexModel
@{
    ViewData["Title"] = AppSettings.Title;
    Layout = "_LoginLayout";
}

@section Head {
    <link href="~/css/SignIn.css" rel="stylesheet" type="text/css" />
}

<table width="100%" style="height:100%;" border="0" cellspacing="0" cellpadding="0">
    <tr>
        <td>
            <table style="margin:auto;height:500px;" border="0" cellpadding="0" cellspacing="0">
                <tr>
                    <td>
                        <form method="post">
                            <div class="centered">
                                <table>
                                    <tr>
                                        <td class="form">
                                            <div>
                                                <table>
                                                    <tr>
                                                        <td colspan="2" class="header"><img src="~/image/1.png" width="500" alt="@AppSettings.Title" /></td>
                                                    </tr>
                                                    <tr>
                                                        <td colspan="2">
                                                            <table class="login">
                                                                @if (Model.ShowCompanySelection)
                                                                {
                                                                    <tr>
                                                                        <td>Company : </td>
                                                                        <td>
                                                                            <select asp-for="Input!.Company" asp-items="Model.Companies" class="value"></select>
                                                                        </td>
                                                                    </tr>
                                                                }
                                                                <tr>
                                                                    <td>User Id : </td>
                                                                    <td><input asp-for="Input!.Username" maxlength="50" class="value" autofocus /></td>
                                                                </tr>
                                                                <tr>
                                                                    <td>Password : </td>
                                                                    <td><input asp-for="Input!.Password" type="password" maxlength="50" class="value" /></td>
                                                                </tr>
                                                                <tr>
                                                                    <td></td>
                                                                    <td>
                                                                        <button type="submit" style="border:0;background:transparent;padding:0;cursor:pointer;">
                                                                            <img src="~/image/button-login.gif" alt="Login" />
                                                                        </button>
                                                                        &nbsp;<a style="display:none;" href="/ChangePassword">Changed Password</a>
                                                                    </td>
                                                                </tr>
                                                            </table>
                                                        </td>
                                                    </tr>
                                                    @if (!string.IsNullOrEmpty(Model.LoginError))
                                                    {
                                                        <tr>
                                                            <td colspan="2" style="color:red;text-align:center;padding-top:8px;">
                                                                @Model.LoginError
                                                            </td>
                                                        </tr>
                                                    }
                                                </table>
                                            </div>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </form>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
