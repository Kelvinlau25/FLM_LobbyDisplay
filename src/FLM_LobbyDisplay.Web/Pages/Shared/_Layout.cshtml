<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @AppSettings.Title</title>

    @* Stylesheets — kept identical to the legacy Main.master so existing pages render correctly *@
    <link href="~/css/Detail.css" rel="stylesheet" type="text/css" />
    <link href="~/css/PenGroup.css" rel="stylesheet" type="text/css" />
    <link href="~/css/prodSystem.css" rel="stylesheet" type="text/css" />
    <link href="~/css/stylesheetmsdn.css" rel="stylesheet" type="text/css" />
    <link href="~/css/jquery-ui-1.8.19.custom.css" rel="stylesheet" type="text/css" />
    <link href="~/css/overcast/jquery-ui-1.8.22.custom.css" rel="stylesheet" type="text/css" />

    @* Scripts — kept identical to the legacy Main.master *@
    <script src="~/js/jquery-1.9.1.js" type="text/javascript"></script>
    <script src="~/js/common.js" type="text/javascript"></script>
    <script src="~/js/commonsearch.js" type="text/javascript"></script>
    <script src="~/js/jquery-ui-1.10.3.custom.js" type="text/javascript"></script>
    <script src="~/js/jquery.mtz.monthpicker.js" type="text/javascript"></script>
    <script src="~/js/jquery.scrollabletab.js" type="text/javascript"></script>

    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <div id="container">
        @RenderBody()
    </div>

    @* Flash-message rendering — replaces the legacy MessageCenter.Show() ScriptManager pop-up *@
    @if (TempData["FlashMessage"] is string flash && !string.IsNullOrWhiteSpace(flash))
    {
        <script type="text/javascript">
            (function () { alert(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(flash))); })();
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
