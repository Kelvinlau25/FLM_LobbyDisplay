<hr /><br />
<strong>Scrolling Text:</strong>&nbsp;
<form method="post" asp-page-handler="SaveScrollingText">
    <textarea name="footerText" style="width:90%;">@Model.ScrollingText</textarea>
    <button type="submit" style="height:26px;vertical-align:top;float:right;">Save</button>
</form>
