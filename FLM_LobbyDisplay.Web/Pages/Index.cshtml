@page
@model FLM_LobbyDisplay.Pages.IndexModel
@{ Layout = null; }
<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=8" />
    <title>@Model.AppTitle</title>
    <link href="@Url.Content("~/css/SignIn.css")" rel="stylesheet" type="text/css" />
</head>
<body>
    <table width="100%" style="height:100%;" border="0" cellspacing="0" cellpadding="0">
        <tr>
            <td>
                <table style="margin:auto;height:500px;" border="0" cellpadding="0" cellspacing="0">
                    <tr>
                        <td>
                            <form method="post">
                                @Html.AntiForgeryToken()
                                <div class="centered">
                                    <table>
                                        <tr>
                                            <td class="form">
                                                <div>
                                                    <table>
                                                        <tr>
                                                            <td colspan="2" class="header">
                                                                <img src="@Url.Content("~/image/1.png")" width="500px" />
                                                            </td>
                                                        </tr>
                                                        <tr>
                                                            <td colspan="2">
                                                                <table class="login">
                                                                    <tr>
                                                                        <td>User Id :</td>
                                                                        <td><input type="text" name="username" id="txtusername" maxlength="50" class="value" /></td>
                                                                    </tr>
                                                                    <tr>
                                                                        <td>Password :</td>
                                                                        <td><input type="password" name="password" id="txtpassword" maxlength="50" class="value" /></td>
                                                                    </tr>
                                                                    <tr>
                                                                        <td></td>
                                                                        <td>
                                                                            <button type="submit" style="border:none;background:none;cursor:pointer;padding:0;">
                                                                                <img src="@Url.Content("~/image/button-login.gif")" alt="Login" />
                                                                            </button>
                                                                        </td>
                                                                    </tr>
                                                                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                                                                    {
                                                                        <tr>
                                                                            <td colspan="2" style="color:red;font-size:12px;font-family:Arial;">
                                                                                @Model.ErrorMessage
                                                                            </td>
                                                                        </tr>
                                                                    }
                                                                </table>
                                                            </td>
                                                        </tr>
                                                    </table>
                                                </div>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </form>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
