<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN" "http://www.w3.org/TR/html4/loose.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=8" />
    <title>@ViewData["Title"]</title>

    <link href="@Url.Content("~/css/Detail.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/css/PenGroup.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/css/prodSystem.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/css/stylesheetmsdn.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/css/jquery-ui-1.8.19.custom.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/css/overcast/jquery-ui-1.8.22.custom.css")" rel="stylesheet" type="text/css" />

    <script src="@Url.Content("~/js/common.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/js/commonsearch.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/js/jquery-1.9.1.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/js/jquery-ui-1.10.3.custom.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/js/jquery-1.4.2.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/js/jquery-1.7.2.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/js/jquery-ui-1.8.22.custom.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/js/jquery-ui-1.8.9.custom.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/js/jquery.mtz.monthpicker.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/js/jquery.scrollabletab.js")" type="text/javascript"></script>

    @await RenderSectionAsync("head", required: false)
    <style type="text/css">
        /* tblbg: replicates ASP.NET GridView default border rendering */
        table.tblbg { border-collapse: collapse; border: 1px solid #999999; }
        table.tblbg td, table.tblbg th { border: 1px solid #999999; padding: 3px 4px; }
        table.tblbg tr.title_bar th { background-color: #DDEEFF; font-family: Arial, Helvetica, sans-serif; font-size: 12px; color: blue; font-weight: bold; }
        table.tblbg tr td { font-family: Arial, Helvetica, sans-serif; font-size: 12px; }
    </style>
</head>
<body>
    <form id="form1" name="form1" method="post">
        <div id="container">
            @RenderBody()
        </div>
    </form>
</body>
</html>
